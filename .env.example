# Server-side only — set these in the Vercel project's Environment Variables
# (Production). They are NOT prefixed with VITE_, so they never reach the browser.

# Your Anthropic API key. Powers Coach Gio, Conversa, Storie and smart Lens.
ANTHROPIC_API_KEY=sk-ant-...

# Shared passcode to open the app + authorise the AI proxy. Leave unset to make
# the app fully public (anyone with the URL can use your Claude credit).
APP_PASSCODE=choose-a-passphrase

# ---------------------------------------------------------------------------
# Local development only (optional): put this in .env.local to let `pnpm dev`
# call Claude directly without running `vercel dev`. Never set it in Vercel —
# a VITE_-prefixed key is baked into the public bundle.
# VITE_ANTHROPIC_API_KEY=sk-ant-...
